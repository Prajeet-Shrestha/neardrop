{
  "name": "neardrop",
  "version": "1.0.1",
  "description": "Finder-inspired LAN file transfer application",
  "main": "electron/main.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --no-tls",
    "test": "node --test 'test/*.test.js'",
    "electron:dev": "ELECTRON_ENABLE_LOGGING=0 electron .",
    "electron:build": "electron-builder",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:win": "electron-builder --win",
    "electron:build:linux": "electron-builder --linux && chmod +x dist-electron/*.AppImage 2>/dev/null || true",
    "electron:build:all": "electron-builder -mwl",
    "build": "pkg .",
    "build:mac-arm64": "pkg . --target node22-macos-arm64 --out-path dist",
    "build:mac-x64": "pkg . --target node22-macos-x64 --out-path dist",
    "build:win": "pkg . --target node22-win-x64 --out-path dist",
    "build:linux": "pkg . --target node22-linux-x64 --out-path dist",
    "release:patch": "npm version patch -m 'release: v%s' && npm run electron:build:all -- --publish always && git push && git push --tags",
    "release:minor": "npm version minor -m 'release: v%s' && npm run electron:build:all -- --publish always && git push && git push --tags",
    "release:major": "npm version major -m 'release: v%s' && npm run electron:build:all -- --publish always && git push && git push --tags"
  },
  "build": {
    "appId": "com.neardrop.app",
    "productName": "NearDrop",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "server.js",
      "src/**",
      "public/**",
      "electron/**",
      "package.json",
      "!dist/**",
      "!dist-electron/**",
      "!public/font/Inter-*Italic*",
      "!public/font/Inter-Black*",
      "!public/font/Inter-ExtraBold*",
      "!public/font/Inter-ExtraLight*",
      "!public/font/Inter-Thin*",
      "!public/font/Inter-Bold*"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Prajeet-Shrestha",
      "repo": "neardrop"
    }
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node22-macos-arm64",
      "node22-macos-x64",
      "node22-win-x64",
      "node22-linux-x64"
    ],
    "outputPath": "dist"
  },
  "author": {
    "name": "Prajeet Shrestha",
    "email": "prazzeettstha@gmail.com"
  },
  "keywords": [
    "lan",
    "file-transfer",
    "local-network"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1"
  }
}
